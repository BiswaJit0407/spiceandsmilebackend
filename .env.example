PORT=5000
CLIENT_URL=http://localhost:5173

MONGO_URI=mongodb://127.0.0.1:27017/spiceandsmile

JWT_SECRET=change_me_to_a_long_random_string
JWT_REFRESH_SECRET=change_me_too

# SMTP (Gmail app password, Zoho, Mailgun SMTP, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your_app_password
MAIL_FROM="Spice&Smile <you@example.com>"

# Anthropic (recipe validation)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5

# Admin bootstrap (first user with this email becomes admin)
ADMIN_EMAIL=admin@example.com
